{
	"$schema": "node_modules/@biomejs/biome/configuration_schema.json",
	"assist": {
		"actions": {
			"recommended": true,
			"source": {
				"noDuplicateClasses": "on",
				"organizeImports": "on",
				"useSortedAttributes": "on",
				"useSortedInterfaceMembers": "on",
				"useSortedKeys": "on",
				"useSortedProperties": "on"
			}
		},
		"enabled": true
	},
	"css": {
		"formatter": {
			"quoteStyle": "single"
		},
		"parser": {
			"tailwindDirectives": true
		}
	},
	"files": {
		"includes": [
			"**",
			"!!**/dist"
		]
	},
	"formatter": {
		"enabled": true,
		"expand": "always",
		"indentStyle": "tab",
		"indentWidth": 4,
		"lineEnding": "lf",
		"lineWidth": 100
	},
	"html": {
		"experimentalFullSupportEnabled": true,
		"formatter": {
			"enabled": true
		},
		"parser": {
			"interpolation": true
		}
	},
	"javascript": {
		"formatter": {
			"jsxQuoteStyle": "single",
			"quoteStyle": "single"
		},
		"parser": {
			"unsafeParameterDecoratorsEnabled": true
		}
	},
	"linter": {
		"domains": {
			"project": "all",
			"test": "all"
		},
		"enabled": true,
		"rules": {
			"complexity": {
				"noImplicitCoercions": "error",
				"noStaticOnlyClass": "warn",
				"useSimplifiedLogicExpression": "error"
			},
			"correctness": {
				"noNodejsModules": "off",
				"noUndeclaredDependencies": {
					"level": "error",
					"options": {
						"devDependencies": true,
						"optionalDependencies": true
					}
				},
				"noUnresolvedImports": "off",
				"noUnusedImports": {
					"fix": "safe",
					"level": "error"
				},
				"noUnusedVariables": "error",
				"useImportExtensions": {
					"level": "error",
					"options": {
						"forceJsExtensions": true
					}
				}
			},
			"performance": {
				"noBarrelFile": "error",
				"noReExportAll": "error"
			},
			"recommended": true,
			"style": {
				"noCommonJs": "error",
				"noDefaultExport": "off",
				"noMagicNumbers": "error",
				"noUnusedTemplateLiteral": "error",
				"useBlockStatements": "error",
				"useImportType": "error",
				"useNamingConvention": "error",
				"useNodejsImportProtocol": {
					"fix": "safe",
					"level": "error"
				},
				"useReadonlyClassProperties": {
					"level": "error",
					"options": {
						"checkAllProperties": true
					}
				},
				"useUnifiedTypeSignatures": "error"
			},
			"suspicious": {
				"noEmptyBlockStatements": "error",
				"noUnassignedVariables": "error",
				"useAwait": "error"
			}
		}
	},
	"root": true,
	"vcs": {
		"clientKind": "git",
		"defaultBranch": "main",
		"enabled": true,
		"useIgnoreFile": true
	}
}
